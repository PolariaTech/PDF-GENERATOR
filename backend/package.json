{
  "name": "epica-pdf-generator-backend",
  "version": "1.0.0",
  "description": "Genera el Resumen de Epica mensual en PDF a partir de un .md, usando OpenAI para estructurar y Playwright para renderizar.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "handlebars": "^4.7.8",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.3",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
